# BARBAROSSA Environment Variables
# Copy to .env and configure for your environment

# Target authorization
BARBAROSSA_AUTHORIZED=false

# Logging
BARBAROSSA_LOG_LEVEL=INFO
BARBAROSSA_LOG_FILE=barbarossa.log

# Proxy settings (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# Output
BARBAROSSA_OUTPUT_DIR=./reports
BARBAROSSA_REPORT_FORMAT=console,json,html,sarif
